{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": false,
    "allowJs": false,
    "isolatedModules": false,
    "incremental": false
  },
  "include": ["src/bot/**/*.ts"],
  "exclude": ["node_modules", ".next", "dist"]
}
